# Add these locations inside the existing iftype.store HTTPS server block.
location = /viral {
    return 301 /viral/;
}

location ^~ /viral/api/ {
    limit_req zone=api_limit burst=15 nodelay;
    limit_conn addr_limit 10;

    proxy_pass https://meme.iftype.store/api/;
    proxy_http_version 1.1;
    proxy_ssl_server_name on;
    proxy_ssl_name meme.iftype.store;
    proxy_set_header Host meme.iftype.store;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}

location ^~ /viral/ {
    root /var/www/viralorigin-admin;
    index index.html;
    try_files $uri $uri/ $uri.html /viral/index.html;

    add_header Cache-Control "no-store" always;
    add_header X-Robots-Tag "noindex, nofollow" always;
}
