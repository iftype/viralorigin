{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- ':(top)apps/web' ':(top)packages/ui'",
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://meme.iftype.store/api/v1/sitemap.xml"
    },
    {
      "source": "/api/:path*",
      "destination": "https://meme.iftype.store/api/:path*"
    }
  ]
}
